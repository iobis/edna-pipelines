manifest {
    name = 'edna-platform-pipelines'
    description = 'Prototype eDNA pipeline: nf-core/ampliseq + Darwin Core output'
    version = '0.1.0'
}

params {
    outdir = 'results'
    ampliseq_outdir = null
    darwincore_outdir = null
    run_ampliseq = true
}

profiles {
    standard {
        process.executor = 'local'
    }

    // Ampliseq runs in Docker (via nested `nextflow run ... -profile docker`).
    // EDNA steps (WORMS_MATCH, BUILD_DARWIN_CORE) still use host Python.
    docker {
        process.executor = 'local'
        params.ampliseq_profile = 'docker'
        docker.enabled = true
    }
}
